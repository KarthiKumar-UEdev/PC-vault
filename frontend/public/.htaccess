# ── PC Vault static frontend — Apache/cPanel config ─────────────────────────
# Uploaded automatically as part of the Next.js export (lives in frontend/public/).

Options -Indexes
DirectorySlash On

<IfModule mod_rewrite.c>
  RewriteEngine On

  # 0. Force HTTPS in production (skipped for localhost dev)
  RewriteCond %{HTTPS} !=on
  RewriteCond %{HTTP_HOST} !^(localhost|127\.0\.0\.1)
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

  # 1. Never rewrite the API (only relevant if the backend is mounted at
  #    /api on this same domain via "Setup Python App").
  RewriteRule ^api(/|$) - [L]

  # 2. Serve real files and directories untouched.
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # 3. SPA-style fallback: /pcs/view?id=x refreshes fine because the export
  #    (trailingSlash: true) writes pcs/view/index.html — this rule catches
  #    extension-less deep links that lack the trailing slash.
  RewriteCond %{REQUEST_URI} !\.[a-zA-Z0-9]{1,8}$
  RewriteCond %{DOCUMENT_ROOT}/$1/index.html -f
  RewriteRule ^(.*?)/?$ /$1/index.html [L]
</IfModule>

# Unknown routes get the exported 404 page
ErrorDocument 404 /404.html

# ── caching ──────────────────────────────────────────────────────────────────
<IfModule mod_headers.c>
  # Hashed Next.js assets are immutable
  <FilesMatch "\.(js|css|woff2?)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  # HTML must always revalidate so deploys show up instantly
  <FilesMatch "\.html$">
    Header set Cache-Control "no-cache"
  </FilesMatch>

  # ── security headers ───────────────────────────────────────────────────────
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "DENY"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  # camera stays available for the QR scan page, everything else is off
  Header always set Permissions-Policy "camera=(self), microphone=(), geolocation=(), payment=()"
  # only sent over HTTPS connections — harmless on plain HTTP
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains" env=HTTPS
</IfModule>
