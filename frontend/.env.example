# Base URL of the FastAPI backend, WITHOUT trailing slash.
# Baked into the static bundle at build time — rebuild after changing it.
# Local dev:
NEXT_PUBLIC_API_URL=http://localhost:8000
# Production (cPanel, API on subdomain or /api path):
# NEXT_PUBLIC_API_URL=https://api.yourdomain.com
# NEXT_PUBLIC_API_URL=https://yourdomain.com/pcvault-api
