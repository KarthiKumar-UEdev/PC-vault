# ── Database ────────────────────────────────────────────────────────────────
# Local dev (SQLite fallback — zero setup):
DATABASE_URL=sqlite:///./pcvault.db
# Local MySQL:
# DATABASE_URL=mysql+pymysql://root:password@localhost:3306/pcvault
# cPanel MySQL (values from cPanel → MySQL Databases):
# DATABASE_URL=mysql+pymysql://cpaneluser_pcvault:DB_PASSWORD@localhost:3306/cpaneluser_pcvault

# ── Encryption ──────────────────────────────────────────────────────────────
# Fernet key for encrypting IP/MAC addresses at rest. Generate a real one:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# NEVER deploy with the example key below.
FERNET_KEY=MDAwMDAwMDAwMDAwMDAwMDAwMDAwMDAwMDAwMDAwMDA=

# ── Role logins (bootstrap only) ────────────────────────────────────────────
# These create the FIRST accounts in the users table when it is empty; after
# that, credentials are changed from the app's Settings page and these values
# are ignored. Leave both passwords empty for local dev (API stays open,
# acts as admin).
# ADMIN: full control. MANAGER: view-only + approve/reject/comment on
# planned builds. With a manager account, converting a build to a real PC
# requires manager approval first.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
MANAGER_USERNAME=manager
MANAGER_PASSWORD=
# How many days a login stays valid (7 recommended in production, 30 default)
SESSION_TTL_DAYS=30

# ── URLs / CORS ─────────────────────────────────────────────────────────────
# Public URL of the frontend (used inside generated QR codes)
FRONTEND_URL=http://localhost:3000
# Comma-separated list of origins allowed to call the API
CORS_ORIGINS=http://localhost:3000

# ── SMTP (cPanel email account) — used only by scripts/send_warranty_alerts.py
SMTP_HOST=mail.yourdomain.com
SMTP_PORT=465
SMTP_USER=alerts@yourdomain.com
SMTP_PASSWORD=changeme
SMTP_FROM=alerts@yourdomain.com
# Where warranty alert emails are sent
ALERT_EMAIL_TO=you@yourdomain.com
# Days ahead to warn about expiring warranties
WARRANTY_ALERT_DAYS=30
