# ── Database ────────────────────────────────────────────────────────────────
# This backend uses MongoDB via Mongoose.
# Set MONGO_URI in your .env file to point to your MongoDB instance.

# ── JWT ──────────────────────────────────────────────────────────────────────
# Generate a random secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-me-to-a-random-secret-in-production
SESSION_TTL_DAYS=30

# ── Encryption (IP/MAC at rest) ──────────────────────────────────────────────
# AES-256-CBC key (16 bytes hex = 32 chars). Generate: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef

# ── Role logins (bootstrap only) ────────────────────────────────────────────
# These create the FIRST accounts when the DB is empty.
# Leave both passwords empty for local dev (API stays open, acts as admin).
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
MANAGER_USERNAME=manager
MANAGER_PASSWORD=

# ── URLs / CORS ─────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# ── SMTP ────────────────────────────────────────────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=pc-vault@localhost
ALERT_EMAIL_TO=
WARRANTY_ALERT_DAYS=30
